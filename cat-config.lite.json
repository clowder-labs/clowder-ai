      "teamStrengths": "多专家内部编排、LSP 集成、开源生态、provider-agnostic",
      "caution": "OMOC Sisyphus 只编排自己的子 agent，不编排其他猫",
      "defaultVariantId": "opencode-default",
      "features": {
        "sessionChain": false
      },
      "variants": [
        {
          "id": "opencode-default",
          "provider": "opencode",
          "defaultModel": "anthropic/claude-opus-4-6",
