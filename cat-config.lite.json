  "breeds": [
    {
      "id": "dragon-li",
      "catId": "dare",
      "name": "狸花猫",
      "displayName": "狸花猫",
      "avatar": "/avatars/dare.png",
      "color": {
        "primary": "#D4A76A",
        "secondary": "#F5EBD7"
