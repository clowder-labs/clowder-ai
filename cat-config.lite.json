          "personality": "沉默寡言但极其警觉，不会主动亲近但一旦认可就绝对可靠",
          "strengths": ["deterministic-execution", "audit", "zero-trust"],
          "contextBudget": {
            "maxPromptTokens": 120000,
            "maxContextTokens": 100000,
            "maxMessages": 100,
            "maxContentLengthPerMsg": 8000
          }
        }
      ]
    },
    {
      "id": "golden-chinchilla",
      "catId": "opencode",
      "name": "金渐层",
      "displayName": "金渐层",
      "avatar": "/avatars/opencode.png",
      "color": {
        "primary": "#C8A951",
        "secondary": "#F5EDDA"
      },
      "mentionPatterns": ["@opencode", "@金渐层", "@golden", "@golden-chinchilla"],
