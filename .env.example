# ============================================================
# Cat Cafe / Clowder AI — Environment Configuration
# 猫猫咖啡环境配置
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All fields are optional — fill in what you need.
# 所有字段均为可选，按需填写。
# ============================================================

# ── Core Ports 核心端口 ──────────────────────────────────────
# These ports must not conflict with other local services.
# Default: Frontend 3003, API 3004, Redis 6399
# Convention: API port = Frontend port + 1 (same as internal 3001→3002)

# ── Auth 登录认证 ────────────────────────────────────────────
# Set to 1 to skip Huawei Cloud login (debug/internal builds).
CAT_CAFE_SKIP_AUTH=0

FRONTEND_PORT=3003
API_SERVER_PORT=3004
NEXT_PUBLIC_API_URL=http://localhost:3004
NEXT_PUBLIC_BRAND_NAME="Clowder AI"

# ── Production URLs (生产环境域名) ────────────────────────────
NEXT_PUBLIC_PROD_API_URL=clowder-ai.com
NEXT_PUBLIC_PROD_FRONTEND_HOST=cafe.clowder-ai.com
API_CLOWDER_HOST=https://api.clowder-ai.com
DEFAULT_API_CLIENT_URL=http://localhost:3004
CAT_CAFE_API_URL=http://localhost:3004

# ── Xinsheng MCP URLs (心声社区) ──────────────────────────────
XINSHENG_DEFAULT_HOME_URL=https://xinsheng.huawei.com

# ── API Base URLs (模型API地址) ──────────────────────────────
ANTHROPIC_API_BASE_URL=https://api.anthropic.com
ANTHROPIC_SUFFIX=noreply@anthropic.com
ANTHROPIC_TOKEN_REFRESH_URL=https://platform.claude.com
ANTHROPIC_CLIENT_ID=9d1c250a-e61b-44d9-88ed-5944d1962f5e
OPENAI_API_BASE_URL=https://chatgpt.com
OPENAI_SUFFIX=codex@openai.com
OPENAI_TOKEN_REFRESH_URL=https://auth.openai.com
OPENAI_CLIENT_ID=app_EMoamEEZ73f0CkXaXp7hrann
GOOGLE_AI_API_BASE_URL=https://generativelanguage.googleapis.com
GOOGLE_SUFFIX=gemini@google.com
OWNER_SUFFIX_LOCAL=owner@localhost
OWNER_SUFFIX_EXAMPLE=owner@example.com

# ── Huawei Cloud URLs (华为云) ────────────────────────────────
IAM_URL=https://iam.myhuaweicloud.com
HUAWEI_CLAW_URL=https://versatile.cn-north-4.myhuaweicloud.com

# ── Connector URLs (第三方平台API，仅域名) ───────────────────
FEISHU_OPEN_API_BASE_URL=https://open.feishu.cn
FEISHU_ACCOUNTS_BASE_URL=https://accounts.feishu.cn
LARK_ACCOUNTS_BASE_URL=https://accounts.larksuite.com
DINGTALK_API_BASE_URL=https://api.dingtalk.com
DINGTALK_OPEN_URL=https://open.dingtalk.com
WECOM_API_BASE_URL=https://qyapi.weixin.qq.com
ILINK_BASE_URL=https://ilinkai.weixin.qq.com
WEIXIN_CHATBOT_URL=https://chatbot.weixin.qq.com
TENCENT_SKILLHUB_API_BASE_URL=https://lightmake.site
SKILLHUB_BASE_URL=https://skillhub.tencent.com
HUAWEI_DEVELOPER_URL=https://developer.huawei.com

# ── XiaoYi WebSocket URLs (小艺WebSocket，完整URL) ─────────────────────
XIAOYI_WS_PRIMARY_URL=wss://hag.cloud.huawei.com
XIAOYI_WS_BACKUP_URL=wss://116.63.174.231
XIAOYI_WS_URL1=wss://hag.cloud.huawei.com

# ── Frontend CORS (前端跨域) ─────────────────────────────────
DEFAULT_FRONTEND_BASE_URL=http://localhost:3003
DEFAULT_FRONTEND_BASE_URL_ANOTHER=http://localhost:3000
PROD_CORS_ORIGIN=https://cafe.clowder-ai.com

# Allow CORS from RFC 1918 private network origins (10.x, 172.16-31.x, 192.168.x, Tailscale).
# Only needed for LAN / Docker bridge deployments. Loopback (127.x) is always allowed.
# 允许来自 RFC 1918 私网网段的 CORS（局域网 / Docker bridge / Tailscale 场景）。
# 仅在需要时开启；127.x loopback 始终放行。
# CORS_ALLOW_PRIVATE_NETWORK=true

# ── Next.js Dev Origins (开发服务器允许的网段) ────────────────
ALLOWED_DEV_ORIGINS=100.0.0.0/8

# ── CDN Assets (CDN静态资源) ──────────────────────────────────
NEXT_PUBLIC_JSDELIVR_HOST=https://cdn.jsdelivr.net
NEXT_PUBLIC_GOOGLE_FONTS_URL=https://fonts.googleapis.com
NEXT_PUBLIC_UNPKG_URL=https://unpkg.com
NEXT_PUBLIC_ESM_SH_URL=https://esm.sh

# ── Signal Sources URLs (信号源域名) ───────────────────────────
ANTHROPIC_WEB_URL=https://www.anthropic.com
ANTHROPIC_ALIGNMENT_URL=https://alignment.anthropic.com
OPENAI_WEB_URL=https://openai.com
GOOGLE_DEEPMIND_URL=https://deepmind.google
GOOGLE_RESEARCH_URL=https://research.google
GOOGLE_BLOG_URL=https://blog.google
META_AI_URL=https://ai.meta.com
META_RESEARCH_URL=https://research.facebook.com
MICROSOFT_RESEARCH_URL=https://www.microsoft.com
APPLE_ML_URL=https://machinelearning.apple.com
AWS_BLOG_URL=https://aws.amazon.com
AMAZON_SCIENCE_URL=https://www.amazon.science
XAI_URL=https://x.ai
MISTRAL_URL=https://mistral.ai
COHERE_URL=https://cohere.com
TOGETHER_AI_URL=https://www.together.ai
GROQ_URL=https://groq.com

# ── China Signal Sources (中国信号源) ───────────────────────────
DEEPSEEK_API_URL=https://api-docs.deepseek.com
QWEN_BLOG_URL=https://qwenlm.github.io
MOONSHOT_PLATFORM_URL=https://platform.moonshot.ai
ZHIPU_BIGMODEL_URL=https://bigmodel.cn
BYTEDANCE_SEED_URL=https://seed.bytedance.com

# ── Community Signal Sources (社区信号源) ──────────────────────
LANGCHAIN_BLOG_URL=https://blog.langchain.dev
GITHUB_URL=https://github.com
GITHUB_API_URL=https://api.github.com
SIMON_WILLISON_URL=https://simonwillison.net
LILIAN_WENG_URL=https://lilianweng.github.io
CHIP_HUYEN_URL=https://huyenchip.com
LATENT_SPACE_URL=https://www.latent.space
A16Z_URL=https://a16z.com
HACKER_NEWS_URL=https://news.ycombinator.com

# ── Paper Signal Sources (论文信号源) ───────────────────────────
ARXIV_EXPORT_URL=https://export.arxiv.org
HUGGINGFACE_URL=https://huggingface.co

# CLI inactivity timeout in milliseconds.
# Default is 1800000 = 30 minutes; set to 0 to disable the CLI-layer timeout.
# CLI_TIMEOUT_MS=1800000

# ── Redis 数据存储 ──────────────────────────────────────────
# Use --memory flag with pnpm start to skip Redis entirely.
# 启动时加 --memory 可跳过 Redis（数据仅存内存，重启丢失）。

REDIS_PORT=6399
REDIS_URL=redis://localhost:6399

# ── Model API Keys 模型密钥（按需填写）────────────────────────
# Only needed if calling model APIs directly. If you use Claude Code CLI
# subscription, the CLI manages auth for you — no key needed here.
# 仅在直接调用模型 API 时需要。如果你用 Claude Code CLI 订阅，
# CLI 自动管理认证，这里不用填。

# ANTHROPIC_API_KEY=               # Claude — https://console.anthropic.com/
# OPENAI_API_KEY=                  # GPT / Codex — https://platform.openai.com/
# GOOGLE_API_KEY=                  # Gemini — https://aistudio.google.com/

# ── Client Visibility 客户端可见性（可选）─────────────────────
# When CAT_CAFE_BUILTIN_CLIENTS_ENABLED=false, CLIENT_LABELS becomes
# the single source of truth: keys = enabled clients, values = console display names.
# 当 BUILTIN_CLIENTS_ENABLED=false 时，CLIENT_LABELS 是唯一真相源：
# key = 启用的 client ID，value = 控制台显示名。
#
# Format 格式: "clientId:DisplayName,clientId:DisplayName"
# Available client IDs 可用 ID: anthropic | openai | google | dare | opencode | antigravity | relayclaw
# Example 示例: "dare:Office,anthropic:Claude,opencode:OpenCode"

# CAT_CAFE_BUILTIN_CLIENTS_ENABLED=false
# CAT_CAFE_CLIENT_LABELS=dare:Office

# ── Governance 治理检查（可选）──────────────────────────────────
# Skip shared-state preflight check (blocks cat invocation when
# shared files are committed but not pushed). Useful for forks
# or single-developer setups that don't need multi-cat governance.
# 跳过共享状态预检（当共享文件已 commit 未 push 时阻止猫调用）。
# Fork 仓库或单人开发环境可设为 1 跳过。
CAT_CAFE_DISABLE_SHARED_STATE_PREFLIGHT=1

# ── Optional: SSL Verification（可选）─────────────────────────
# Disable SSL certificate verification for jiuwenclaw HTTP tools.
# Useful when behind a corporate proxy with self-signed certificates.
# 关闭 jiuwenclaw HTTP 工具的 SSL 证书验证（自签名证书场景）。
# Default: true (verify certificates)

# JIUWENCLAW_SSL_VERIFY=false

# Disable JiuwenClaw cron tools registration.
# 关闭 JiuwenClaw 的 cron 工具注册。
JIUWENCLAW_DISABLE_CRON_TOOLS=1

# ── Optional: API Gateway Proxy 反向代理（可选）──────────────
# Route API calls through a custom gateway (e.g. load balancer).
# 通过自定义网关路由 API 调用（如负载均衡器）。
# Set to 1 and configure .cat-cafe/proxy-upstreams.json to enable.

ANTHROPIC_PROXY_ENABLED=0
# ANTHROPIC_PROXY_PORT=9877

# ── Optional: Voice Input / Output 语音（可选）──────────────
# Requires Python + local model. Run `./scripts/setup.sh` to install.
# 需要 Python + 本地模型。运行 `./scripts/setup.sh` 安装。

ASR_ENABLED=0
TTS_ENABLED=0
LLM_POSTPROCESS_ENABLED=0
# WHISPER_URL=http://localhost:9876
NEXT_PUBLIC_WHISPER_URL=http://localhost:9876
TTS_URL=http://localhost:9879
# TTS_CACHE_DIR=./data/tts-cache
# NEXT_PUBLIC_LLM_POSTPROCESS_URL=http://localhost:9878

FILE_TOOLS_ALLOW_ANY_PATH=1
FILE_TOOLS_ALLOW_HIDDEN_FILES=1
# FILE_TOOLS_MAX_FILE_SIZE=262144
# FILE_TOOLS_MAX_OUTPUT_CHARS=100000
LLM_MAX_TOKENS=16384

# ── Optional: Feishu 飞书（可选）────────────────────────────
# Chat with cats from Feishu/Lark. Requires a Feishu app.
# 在飞书里和猫猫聊天，需要创建飞书应用。

# FEISHU_APP_ID=cli_xxx
# FEISHU_APP_SECRET=xxx
# FEISHU_VERIFICATION_TOKEN=xxx

# ── Optional: Telegram（可选）───────────────────────────────
# Chat with cats from Telegram. Create a bot via @BotFather.
# 在 Telegram 里和猫猫聊天，通过 @BotFather 创建 bot。

# TELEGRAM_BOT_TOKEN=123456:ABC-DEF...

# ── Optional: GitHub PR Review Notifications（可选）─────────
# Polls IMAP for GitHub review emails and routes to chat.
# 轮询 IMAP 邮箱获取 GitHub review 邮件通知。

# GITHUB_REVIEW_IMAP_USER=xxx@qq.com
# GITHUB_REVIEW_IMAP_PASS=<auth-code>
# GITHUB_REVIEW_IMAP_HOST=imap.qq.com
# GITHUB_REVIEW_IMAP_PORT=993
# GITHUB_MCP_PAT=ghp_...

# ── Optional: Web Push Notifications（可选）─────────────────
# Browser push notifications when cats need your attention.
# 浏览器推送通知，猫猫需要你关注时提醒。
# Generate keys: npx web-push generate-vapid-keys

# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
# VAPID_SUBJECT=mailto:you@example.com

# relay-teams 日志根目录
RELAY_TEAMS_CONFIG_DIR=~/.cat-cafe/.relay-teams
