{
  "name": "@office-claw/plugin-api",
  "version": "0.1.0",
  "type": "module",
  "description": "Plugin contracts for OfficeClaw extensions. Auth is the first extension point.",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./auth": {
      "import": "./dist/auth.js",
      "types": "./dist/auth.d.ts"
    }
  },
  "files": [
