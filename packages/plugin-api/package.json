    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "prepublishOnly": "tsc"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  }
}
